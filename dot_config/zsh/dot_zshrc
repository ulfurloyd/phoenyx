### Exports ###
###############

export EDITOR=nvim

###############
### Aliases ###
###############
# General
cd() { z "$@"; }
nf() { nerdfetch "$@"; }
pf() { pfetch "$@"; }
ff() { fastfetch "$@"; }
ls() { exa -lah "$@"; }
v() { nvim "$@"; }
vif() { nvim $(fzf) "$@"; }
gg() { lazygit "$@"; }
tree() { tre -e automatic "$@"; }
cz() { chezmoi "$@"; }

# git
gs() { git status "$@"; }
ga() { git add "$@"; }
gaa() { git add .; }
gc() { git commit "$@"; }
gcm() { git commit -m "$@"; }
gp() { git push "$@"; }
gpl() { git pull "$@"; }
gi() { git init "$@"; }
gcl() { git clone "$@"; }

# branching
gb() { git branch "$@"; }
gba() { git branch -a "$@"; }
gco() { git checkout "$@"; }
gcb() { git checkout -b "$@"; }
gsw() { git switch "$@"; }
gswc() { git switch -c "$@"; }

# logs and diffs
gl() { git log --oneline --graph --decorate "$@"; }
gd() { git diff "$@"; }
gds() { git diff --staged "$@"; }

######################
### Pre-Shell Init ###
######################

# Starship prompt
eval "$(starship init zsh)"

# fzf integration
eval "$(fzf --zsh)"

# Zoxide
eval "$(zoxide init zsh)"

