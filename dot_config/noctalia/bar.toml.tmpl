[bar]
order = ["primary", "secondary"]

[bar.primary]
background_opacity = 0.5
center = ["clock", "date"]
{{ if eq .chezmoi.hostname "nyx" }}
end = ["tray", "volume", "screen_recorder", "clipboard"]
{{ else if eq .chezmoi.hostname "hermes" }}
end = ["tray", "network", "bluetooth", "volume", "brightness", "battery", "clipboard"]
{{ end }}
position = "bottom"
radius = 15
scale = 1.0499999523162842
start = ["workspaces", "active_window"]
thickness = 40
widget_spacing = 8

[bar.secondary]
background_opacity = 0.5
capsule = false
capsule_groups = ["start", "center", "end"]
center = ["media"]
end = ["weather", "notifications"]
position = "top"
radius = 15
scale = 1.0499999523162842
start = ["cpu", "ram", "temp"]
thickness = 40
widget_spacing = 8

[widget.audio_visualizer]
capsule = false
capsule_group = "center"
show_when_idle = false

[widget.clock]
format = "{:%H:%M:%S}"

[widget.cpu]
capsule_group = "start"

[widget.ram]
capsule_group = "start"

[widget.temp]
capsule_group = "start"

[widget.media]
capsule = false
capsule_group = "center"
max_length = 300.0
min_length = 100.0

[widget.notifications]
capsule = false
capsule_group = "end"
capsule_padding = 15.0

[widget.screen_recorder]
type = "scripted"
script = "scripts/screen_recorder.lua"
scope = "shared"
directory = ""
filename_pattern = "recording_%Y%m%d_%H%M%S"
video_source     = "portal"
video_codec      = "h264"
audio_codec      = "opus"
audio_source     = "default_output"
quality          = "high"
frame_rate       = 60
color_range      = "limited"
resolution       = "original"
show_cursor      = true
copy_to_clipboard = false
restore_portal   = false
replay_enabled   = false
replay_duration  = 30
replay_storage   = "ram"
hide_inactive    = false

[widget.weather]
capsule = false
capsule_group = "end"
