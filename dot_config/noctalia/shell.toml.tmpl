[shell]
avatar_path = "/home/wolf/Pictures/pfp/Midra.jpg"
font_family = "Fira Sans"
niri_overview_type_to_launch_enabled = true
polkit_agent = true
telemetry_enabled = false
{{ if eq .chezmoi.hostname "nyx" }}
ui_scale = 1.0
{{ else if eq .chezmoi.hostname "hermes" }}
ui_scale = 1.1000000238418579
{{ end }}

[[shell.session.actions]]
action = "lock"
enabled = true
shortcut = "l"
variant = "default"

[[shell.session.actions]]
action = "logout"
enabled = true
shortcut = "o"
variant = "default"

[[shell.session.actions]]
action = "suspend"
enabled = true
shortcut = "u"
variant = "default"

[[shell.session.actions]]
action = "reboot"
enabled = true
shortcut = "r"
variant = "default"

[[shell.session.actions]]
action = "shutdown"
enabled = true
shortcut = "s"
variant = "destructive"

[shell.panel]
attach_session = true
attach_launcher = true
clipboard_placement = "attached"
transparency_mode = "glass"
