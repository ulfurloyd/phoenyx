#!/usr/bin/env python3

import sys
import re
from pathlib import Path
from mutagen import File


def parse_lrc(text):
    """
    Parses LRC content into [(text, timestamp_ms), ...]
    Supports multiple timestamps per line.
    """
    pattern = re.compile(r"\[(\d+):(\d+)(?:\.(\d+))?\]")
    result = []

    for line in text.splitlines():
        matches = list(pattern.finditer(line))
        if not matches:
            continue

        lyric = line[matches[-1].end() :].strip()
        if not lyric:
            continue

        for match in matches:
            minutes = int(match.group(1))
            seconds = int(match.group(2))
            frac = match.group(3) or "0"

            # Normalize fractional part to milliseconds
            millis = int(frac.ljust(3, "0")[:3])

            timestamp = (minutes * 60 + seconds) * 1000 + millis

            result.append((lyric, timestamp))  # ✅ correct order

    return sorted(result, key=lambda x: x[1])


def embed_lyrics(audio_path):
    audio_path = Path(audio_path)
    lrc_path = audio_path.with_suffix(".lrc")

    if not lrc_path.exists():
        return

    lyrics_text = lrc_path.read_text(encoding="utf-8").strip()
    if not lyrics_text:
        return

    audio = File(audio_path)

    if audio is None:
        print(f"Unsupported file: {audio_path}")
        return

    ext = audio_path.suffix.lower()

    try:
        if ext == ".flac":
            audio["LYRICS"] = lyrics_text

        elif ext == ".mp3":
            from mutagen.id3 import SYLT

            parsed = parse_lrc(lyrics_text)

            if not parsed:
                print(f"No valid LRC timestamps in {lrc_path}")
                return

            if audio.tags is None:
                audio.add_tags()

            audio.tags.delall("SYLT")

            audio.tags.add(
                SYLT(encoding=3, lang="eng", format=2, type=1, desc="", text=parsed)
            )

        else:
            print(f"Skipping unsupported format: {audio_path}")
            return

        audio.save()
        print(f"Embedded SYLT → {audio_path}")

    except Exception as e:
        print(f"Error processing {audio_path}: {e}")


if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: embed_lyrics.py <audio-file>")
        sys.exit(1)

    embed_lyrics(sys.argv[1])
